{
  "compilerOptions": {
    "target": "ES6",
    "allowJs": true,
    "module": "NodeNext",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "sourceMap": true,
    "outDir": "dist",
    "moduleResolution": "nodenext",
    "resolveJsonModule": true,
    "jsx": "react-jsx"
  },
  "include": ["./"]
}
